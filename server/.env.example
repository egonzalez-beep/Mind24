# PostgreSQL (Railway injects DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Session signing (use a long random string in production)
SESSION_SECRET="replace-with-openssl-rand-hex-32"

# Optional: credentialed CORS if the static UI is on another origin
# CLIENT_ORIGINS="https://app.example.com"

# Railway / reverse proxy: trust X-Forwarded-* (defaults true in production in code)
# TRUST_PROXY=1

NODE_ENV=development
PORT=3000

# Administrador general (superadmin): solo este correo + hash bcrypt de su contraseña.
# En desarrollo, el hash por defecto en código corresponde a la contraseña "mind24".
# En producción define SUPERADMIN_PASSWORD_HASH (bcrypt) y SUPERADMIN_EMAIL.
# SUPERADMIN_EMAIL="e.gonzalez@talento24.com"
# SUPERADMIN_PASSWORD_HASH="$2a$12$..."
