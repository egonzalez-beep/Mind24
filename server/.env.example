# PostgreSQL (Railway injects DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Session signing (use a long random string in production)
SESSION_SECRET="replace-with-openssl-rand-hex-32"

# Optional: credentialed CORS if the static UI is on another origin
# CLIENT_ORIGINS="https://app.example.com"

# Opcional: ruta absoluta al index.html si no usas la raíz del repo ni server/public/index.html
# FRONTEND_INDEX_PATH="/ruta/absoluta/index.html"

NODE_ENV=development
PORT=3000

# El administrador de plataforma (panel «Administrador general») es un User con rol master_admin
# (p. ej. e.gonzalez@talento24.com / mind24), creado por bootstrap al arrancar si no existe.
