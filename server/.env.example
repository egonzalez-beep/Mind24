# Copy to server/.env (never commit .env). Railway: set these in the service variables.

DATABASE_URL=your_database_url
SESSION_SECRET=change_me

# Platform master_admin: each boot syncs this email to role master_admin (and clears organizationId if set).
# New user: requires PLATFORM_ADMIN_PASSWORD. Existing user: password hash updated only if env password differs.
# If PLATFORM_ADMIN_PASSWORD is empty and the user does not exist, no user is created.
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=change_me

# Optional: demo empresa + candidato on startup (all four required; omit to skip demo bootstrap).
# BOOTSTRAP_DEMO_ADMIN_EMAIL=
# BOOTSTRAP_DEMO_ADMIN_PASSWORD=
# BOOTSTRAP_DEMO_CANDIDATE_EMAIL=
# BOOTSTRAP_DEMO_CANDIDATE_PASSWORD=

# Optional: credentialed CORS if the static UI is on another origin
# CLIENT_ORIGINS=https://app.example.com

# Optional: absolute path to index.html if not using repo root or server/public/index.html
# FRONTEND_INDEX_PATH=

NODE_ENV=development
PORT=3000

# Destructive seed (`npm run db:seed`): requires all of the following (see server/README.md).
# SEED_ORG_SLUG=demo
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_CANDIDATE_EMAIL=
# SEED_CANDIDATE_PASSWORD=
